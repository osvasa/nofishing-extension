{
  "manifest_version": 3,
  "name": "NøFishing AI",
  "version": "1.0.0",
  "description": "AI-powered phishing and scam detection. Stay safe from dangerous websites in real time.",
  "permissions": [
    "storage",
    "tabs",
    "activeTab",
    "scripting",
    "webNavigation"
  ],
  "host_permissions": [
    "<all_urls>"
  ],
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/fish-no-symbol-red.png",
      "48": "icons/fish-no-symbol-red.png",
      "128": "icons/fish-no-symbol-red.png"
    }
  },
  "icons": {
    "16": "icons/fish-no-symbol-red.png",
    "48": "icons/fish-no-symbol-red.png",
    "128": "icons/fish-no-symbol-red.png"
  },
  "background": {
    "service_worker": "background.js",
    "scripts": ["background.js"]
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "css": ["content.css"],
      "run_at": "document_idle"
    }
  ],
  "externally_connectable": {
    "matches": ["https://nofishing.ai/*", "https://*.nofishing.ai/*"]
  },
  "web_accessible_resources": [
    {
      "resources": ["icons/fish-no-symbol-red.png", "icons/logo.png", "payment-success.html", "supabase.js"],
      "matches": ["<all_urls>"]
    }
  ]
}
